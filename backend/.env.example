MONGO_URI=your_mongodb_connection_string_here
DB_NAME=wsxcblqh_ix
DB_USER=wsxcblqh_thanh
DB_PASS=

EMAIL_USER=stareduelt@gmail.com
EMAIL_PASS=
EMAIL_TO=thanhlh@siec-star.edu.vn
PORT=5000
REACT_APP_API_URL=https://ix.star-siec.edu.vn
# Optional: URL of the frontend app used for 'Xem chi tiết (UI)' links in emails
# e.g. http://localhost:3000 (development) or https://ix.star-siec.edu.vn (production)
FRONTEND_URL=http://localhost:3000

# Social login
# Google: use the same OAuth client IDs that your frontend app uses. Multiple IDs can be
# provided as a comma-separated list when you have separate development/production clients.
GOOGLE_CLIENT_IDS=your_google_client_id_here
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
ZALO_APP_ID=your_zalo_app_id_here
ZALO_APP_SECRET=your_zalo_app_secret_here
# Optional: if omitted, the frontend sends its current /login URL during the Zalo PKCE callback.
ZALO_REDIRECT_URI=http://localhost:3000/login

GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional auth tuning
# Students can keep a longer access token during a 60-minute test session.
JWT_ACCESS_EXPIRES_IN_STUDENT=120m
JWT_ACCESS_EXPIRES_IN=15m

# Optional API limiter tuning
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=600
API_RUNTIME_SYNC_RATE_LIMIT_WINDOW_MS=60000
API_RUNTIME_SYNC_RATE_LIMIT_MAX=1800
API_AI_RATE_LIMIT_WINDOW_MS=60000
API_AI_RATE_LIMIT_MAX=120
